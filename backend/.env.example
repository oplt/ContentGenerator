APP_NAME=SignalForge
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/content_generator
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me
CSRF_SECRET=change-me-again
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
FRONTEND_URL=http://localhost:5173
SEND_AUTH_EMAIL_ON_SIGNUP=false
COOKIE_SECURE=false
ENCRYPTION_KEY=
EXTERNAL_SECRET_REFERENCES_JSON={}
STORAGE_BUCKET=content-generator
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_USE_SSL=false
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/content-generator
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
LLM_PROVIDER=mock
LLM_MODEL=mock-gpt
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=2
LLM_JSON_ENFORCEMENT=best_effort
LLM_TASK_MODELS_JSON={}
LLM_BASE_URL=
LLM_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
VLLM_BASE_URL=http://localhost:8001/v1
LLAMACPP_BASE_URL=http://localhost:8080/v1
EMBEDDINGS_PROVIDER=hashing
EMBEDDINGS_MODEL=nomic-embed-text
INGESTION_DISABLE_AFTER_FAILURES=5
ENABLE_X_SIGNAL_CONNECTOR=false
ENABLE_BLUESKY_SIGNAL_CONNECTOR=false
ENABLE_GOOGLE_TRENDS_CONNECTOR=false
ENABLE_OFFICIAL_SOURCE_CONNECTOR=true
GOOGLE_TRENDS_REGION=US
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_CALLBACK_SIGNING_SECRET=
WHATSAPP_PROVIDER=stub
WHATSAPP_VERIFY_TOKEN=dev-verify-token
WHATSAPP_DEFAULT_RECIPIENT=+10000000000
SOCIAL_DRY_RUN_BY_DEFAULT=true
PUBLIC_URL=http://localhost:8000
DEMO_SEED_ENABLED=true
DEMO_ADMIN_EMAIL=demo@example.com
DEMO_ADMIN_PASSWORD=password1234
DEMO_ADMIN_NAME=Demo Operator
OTLP_ENDPOINT=
OTLP_INSECURE=true
